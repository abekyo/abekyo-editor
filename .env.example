# ============================================
# Abekyo Editor - Environment variables
# ============================================
# Copy this file to .env.local (or .env) and fill in values.
#
#   cp .env.example .env.local
#
# Nothing here is required for local development — the app runs with
# no env vars set. These are all optional overrides.
# ============================================

# Public base URL used for canonical links, hreflang alternates, and
# server-side absolute URL resolution (inside /api/render).
# Default: http://localhost:3000
# Set this to your deployment URL in production, e.g. https://editor.example.com
# NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Repository URL used by the landing page GitHub CTAs and footer links.
# When unset, the GitHub buttons are hidden entirely (no dead placeholder link).
# NEXT_PUBLIC_GITHUB_URL=https://github.com/your-org/your-repo

# --- Render rate limiting (optional) ---
# Max simultaneous /api/render jobs across the process. Remotion is heavy
# (Chromium + ffmpeg); raise this only on beefy hardware.
# Default: 1
# RENDER_MAX_CONCURRENT=1

# Per-IP sliding window length in milliseconds.
# Default: 600000 (10 minutes)
# RENDER_RATE_LIMIT_WINDOW_MS=600000

# Max /api/render requests per IP within the window.
# Default: 10
# RENDER_RATE_LIMIT_MAX=10
